generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//Database enums
enum UserRole {
  CLIENT
  RIDER
  STORE_MANAGER
  ADMIN
}

